# Example environment variables for the fulfillment app.
#
# LOCAL DEV:  copy to backend/.env and fill in — most are optional for dev,
#             defaults in code target SQLite + localhost.
# RAILWAY:    set each of these in the Railway service's "Variables" tab.
#             Railway's Postgres plugin auto-injects DATABASE_URL.

# --- Database ---
# Left blank locally → uses sqlite:///./fulfillment.db
# On Railway: auto-provided by the Postgres plugin (don't set manually)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# --- App URL (used to build Shopify OAuth redirect URI) ---
# Local default: http://localhost:8000
# On Railway: https://<your-app>.up.railway.app
APP_BASE_URL=http://localhost:8000

# Where to redirect the browser after a successful Shopify OAuth connect.
# Local dev: the Vite dev server. Production: the deployed app's /orders page.
SHOPIFY_SUCCESS_REDIRECT=http://localhost:5173/orders?shopify=connected

# --- CORS ---
# Comma-separated list of allowed origins. Needed in dev because Vite serves
# the UI from :5173 but calls the API on :8000 (proxied). In production the
# frontend is served from the same origin so CORS is less relevant.
CORS_ORIGINS=http://localhost:5173

# --- Shopify ---
SHOPIFY_SHOP_DOMAIN=your-shop.myshopify.com
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
# Optional: skip the /connect OAuth flow by pasting a token directly.
# Normally leave blank and use /api/shopify/connect instead.
# SHOPIFY_ACCESS_TOKEN=

# --- ShipStation ---
SS_API_KEY=
SS_API_SECRET=

# --- Anthropic (inventory-count scan via Claude) ---
ANTHROPIC_API_KEY=

# --- Google Sheets service account (optional) ---
# Locally: path to a JSON file (backend/credentials.json by default)
# On Railway: paste the full JSON as a single-line env var; code should read
# from GOOGLE_CREDENTIALS_JSON first, fall back to the file path.
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
